        "func": "// Ensayo seleccionado desde el dropdown: \"Bomba 1\", \"Bomba 2\", \"Serie\", \"Paralelo\"\nlet ensayo = (msg.payload || \"\").toString().trim();\nflow.set(\"ensayo_actual\", ensayo);\n\n// SVG del circuito\nconst grupos_svg = [\n    \"SVG_B1\",\n    \"SVG_B2\",\n    \"SVG_SERIE\",\n    \"SVG_PARALELO\"\n];\n\n// Grupos hidráulicos\nconst grupos_hidraulicos = [\n    \"HYD_COMMON\",\n    \"HYD_B1\",\n    \"HYD_B2\"\n];\n\n// Grupos eléctricos\nconst grupos_electricos = [\n    \"ELEC_B1\",\n    \"ELEC_B2\"\n];\n\n// Grupos de variadores\nconst grupos_vfd = [\n    \"VFD_B1\",\n    \"VFD_B2\"\n];\n\n// Armamos lista con TODOS los grupos de la página SCADA\nlet todos = []\n    .concat(grupos_svg)\n    .concat(grupos_hidraulicos)\n    .concat(grupos_electricos)\n    .concat(grupos_vfd);\n\n// Por defecto: ocultamos todo\nlet show = [];\nlet hide = [...todos];\n\n// Función auxiliar: agrega grupos a 'show' y los saca de 'hide'\nfunction addShow(lista) {\n    lista.forEach(g => {\n        if (!show.includes(g)) show.push(g);\n        hide = hide.filter(h => h !== g);\n    });\n}\n\n// Elegimos qué mostrar según el ensayo\nswitch (ensayo) {\n    case \"Bomba 1\":\n        addShow([\n            \"SVG_B1\",\n            \"HYD_COMMON\",\n            \"HYD_B1\",\n            \"ELEC_B1\",\n            \"VFD_B1\"\n        ]);\n        break;\n\n    case \"Bomba 2\":\n        addShow([\n            \"SVG_B2\",\n            \"HYD_COMMON\",\n            \"HYD_B2\",\n            \"ELEC_B2\",\n            \"VFD_B2\"\n        ]);\n        break;\n\n    case \"Serie\":\n        addShow([\n            \"SVG_SERIE\",\n            \"HYD_COMMON\",\n            \"HYD_B1\",\n            \"HYD_B2\",\n            \"ELEC_B1\",\n            \"ELEC_B2\",\n            \"VFD_B1\",\n            \"VFD_B2\"\n        ]);\n        break;\n\n    case \"Paralelo\":\n        addShow([\n            \"SVG_PARALELO\",\n            \"HYD_COMMON\",\n            \"HYD_B1\",\n            \"HYD_B2\",\n            \"ELEC_B1\",\n            \"ELEC_B2\",\n            \"VFD_B1\",\n            \"VFD_B2\"\n        ]);\n        break;\n\n    default:\n        // Si llega algo raro, no mostramos nada\n        break;\n}\n\n// ⚠️ ACA VIENE LA CLAVE PARA QUE FUNCIONE:\n// En Dashboard 2, el ui-control acepta un payload con:\n//  - page: \"NombrePagina\"\n//  - groups: { show: [...], hide: [...] }\n\nmsg.payload = {\n    page: \"SCADA\",      // Nombre exacto de la PAGE\n    groups: {\n        show: show,\n        hide: hide\n    }\n};\n\nreturn msg;\n",
