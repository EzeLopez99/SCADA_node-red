        "func": "// Lee el valor del %MW60012 desde el payload\nlet raw = Array.isArray(msg.payload) ? msg.payload[0] : msg.payload;\nlet texto;\n\n// Mapea el código al estado del controlador\nswitch (raw) {\n    case 0:\n        texto = \"EMPTY (sin configuración)\";\n        break;\n    case 2:\n        texto = \"STOPPED (CPU en STOP)\";\n        break;\n    case 3:\n        texto = \"RUNNING (CPU en RUN)\";\n        break;\n    case 4:\n        texto = \"HALTED (detenida por fallo)\";\n        break;\n    case 5:\n        texto = \"POWERLESS (sin alimentación)\";\n        break;\n    default:\n        texto = \"Estado desconocido (\" + raw + \")\";\n        break;\n}\n\n// Lo que va al nodo de texto del dashboard\nmsg.payload = texto;\n// opcional, por si querés usarlo en otro lado\nmsg.plc_status_code = raw;\n\nreturn msg;\n",
