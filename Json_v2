        "name": "Fusionar Elec+Hyd (Contexto)",
        "func": "var modo = global.get(\"modo_ensayo\");\nvar nombreArchivo = global.get(\"nombre_archivo\") || \"Ensayo_Sin_Nombre\";\nvar elec = flow.get(\"elec_last\") || {};\nvar hyd = flow.get(\"hyd_last\") || {};\n\nvar now = new Date();\nvar opciones = { timeZone: 'America/Argentina/Buenos_Aires', hour12: false };\nvar ts = now.toLocaleDateString('es-AR', opciones) + ' ' + now.toLocaleTimeString('es-AR', opciones);\n\n// Estructura de datos REORDENADA según tu pedido\nvar datos = {\n    Time: ts,\n    Modo: modo || \"Sin Seleccion\",\n    // Hidráulica primero\n    Caudal: hyd.FE_AO || 0,\n    Temp: hyd.TR_01 || 0,\n    PR_1Q: hyd.PR_1Q || 0,\n    PR_2Q: hyd.PR_2Q || 0,\n    PR_11: hyd.PR_11 || 0, // Ahora se guarda en bar\n    PR_12: hyd.PR_12 || 0,\n    PR_21: hyd.PR_21 || 0,\n    PR_22: hyd.PR_22 || 0,\n    // Eléctrica Bomba 1\n    B1_Pot: elec.POT_B1 || 0,\n    B1_I: elec.CURRENT_B1 || 0,\n    B1_V: elec.V_FASE_B1 || 0,\n    B1_F: elec.FREQUENCY_B1 || 0,\n    B1_PF: elec.PF_B1 || 0,\n    // Eléctrica Bomba 2\n    B2_Pot: elec.POT_B2 || 0,\n    B2_I: elec.CURRENT_B2 || 0,\n    B2_V: elec.V_FASE_B2 || 0,\n    B2_F: elec.FREQUENCY_B2 || 0,\n    B2_PF: elec.PF_B2 || 0\n};\n\nmsg.filename = \"./\" + nombreArchivo + \".csv\";\nmsg.payload = datos;\nreturn msg;",
